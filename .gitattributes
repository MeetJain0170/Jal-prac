# Normalize line endings to avoid LF/CRLF warnings/noisy diffs on Windows.
# Keep repository text files as LF.
* text=auto eol=lf

# Common binary formats
*.pt  -text
*.pth -text
*.ckpt -text
*.onnx -text
*.engine -text
*.tflite -text
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.webp -text
*.pdf -text

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
